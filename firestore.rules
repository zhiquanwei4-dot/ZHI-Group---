rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields: uid, email, displayName, role
    //
    // Collection: testProjects
    // Document ID: projectId
    // Fields: id, name, kuaiyicePrice, kuaiyiceDetail, compassPrice, compassDetail, recommendation, hkuAvailable, cityuAvailable, milesAvailable, mainlandAvailable, remarks
    //
    // Collection: localItems
    // Document ID: itemId
    // Fields: id, name, platform, instrumentName, hkuUserFee, billingMethod, remarks
    //
    // Collection: registrations
    // Document ID: registrationId
    // Fields: id, date, projectName, sampleName, sampleCount, testRequirements, contactPerson, contactPhone, status, authorUid
    //
    // Collection: approvals
    // Document ID: approvalId
    // Fields: id, date, projectName, sampleName, sampleCount, testRequirements, applicant, region, quoteType, estimatedFee, status, approvalRemarks, approvalDate, authorUid
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email.matches('(?i)zhiquanwei4@gmail\\.com')
        );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'role']) &&
             data.uid is string && data.email is string && data.role is string &&
             data.role in ['admin', 'user'];
    }

    function isValidProject(data) {
      return data == null || (
        hasRequiredFields(['id', 'name']) &&
        data.id is string && data.name is string
      );
    }

    function isValidRegistration(data) {
      return hasRequiredFields(['id', 'testProject', 'sampleName', 'sampleCount', 'status']) &&
             data.id is string && data.testProject is string && data.sampleName is string &&
             data.sampleCount is int && data.status is string &&
             data.status in ['待核对', '已核对'];
    }

    function isValidApproval(data) {
      return hasRequiredFields(['id', 'testProject', 'sampleName', 'sampleCount', 'status']) &&
             data.id is string && data.testProject is string && data.sampleName is string &&
             data.sampleCount is int && data.status is string &&
             data.status in ['待审批', '通过', '驳回', '无需审批'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /testProjects/{projectId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /localItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow read: if true;
      allow create: if isValidRegistration(request.resource.data) && (request.resource.data.status == '待核对' || isAdmin());
      allow update: if isValidRegistration(request.resource.data) && (isAdmin() || (request.resource.data.status == resource.data.status));
      allow delete: if isAdmin();
    }

    match /approvals/{approvalId} {
      allow read: if true;
      allow create: if isValidApproval(request.resource.data) && (request.resource.data.status == '待审批' || isAdmin());
      allow update: if isValidApproval(request.resource.data) && (isAdmin() || (request.resource.data.status == resource.data.status));
      allow delete: if isAdmin();
    }
  }
}
