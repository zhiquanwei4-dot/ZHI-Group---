{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    },
    "TestProject": {
      "title": "TestProject",
      "description": "Test project information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "kuaiyicePrice": { "type": "string" },
        "kuaiyiceDetail": { "type": "string" },
        "compassPrice": { "type": "string" },
        "compassDetail": { "type": "string" },
        "recommendation": { "type": "string" },
        "hkuAvailable": { "type": "boolean" },
        "cityuAvailable": { "type": "boolean" },
        "milesAvailable": { "type": "boolean" },
        "mainlandAvailable": { "type": "boolean" },
        "remarks": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "LocalPlatformItem": {
      "title": "LocalPlatformItem",
      "description": "Local platform instrument information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "platform": { "type": "string" },
        "instrumentName": { "type": "string" },
        "hkuUserFee": { "type": "string" },
        "billingMethod": { "type": "string" },
        "remarks": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "RegistrationRecord": {
      "title": "RegistrationRecord",
      "description": "Sample registration record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "projectName": { "type": "string" },
        "sampleName": { "type": "string" },
        "sampleCount": { "type": "integer" },
        "testRequirements": { "type": "string" },
        "contactPerson": { "type": "string" },
        "contactPhone": { "type": "string" },
        "status": { "type": "string", "enum": ["待核对", "已核对"] },
        "authorUid": { "type": "string" }
      },
      "required": ["id", "projectName", "sampleName", "sampleCount", "status"]
    },
    "ApprovalRecord": {
      "title": "ApprovalRecord",
      "description": "Sample approval record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "projectName": { "type": "string" },
        "sampleName": { "type": "string" },
        "sampleCount": { "type": "integer" },
        "testRequirements": { "type": "string" },
        "applicant": { "type": "string" },
        "region": { "type": "string" },
        "quoteType": { "type": "string" },
        "estimatedFee": { "type": "number" },
        "status": { "type": "string", "enum": ["待审批", "已通过", "已驳回"] },
        "approvalRemarks": { "type": "string" },
        "approvalDate": { "type": "string" },
        "authorUid": { "type": "string" }
      },
      "required": ["id", "projectName", "sampleName", "sampleCount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/testProjects/{projectId}": { "schema": "TestProject", "description": "Test projects" },
    "/localItems/{itemId}": { "schema": "LocalPlatformItem", "description": "Local platform items" },
    "/registrations/{registrationId}": { "schema": "RegistrationRecord", "description": "Registration records" },
    "/approvals/{approvalId}": { "schema": "ApprovalRecord", "description": "Approval records" }
  }
}
